waveqlab3d input file: asymmetric two-block anelastic-Q4 MPI topology test

&problem_list
 name = 'data/test_anelastic_Q4_asymmetric', problem = 'default',
 response = 'anelastic-Q4', nblocks = 2, t_final = 0.002d0, CFL = 0.25d0,
 coupling = 'locked', fd_type = 'upwind', order = 4,
 mesh_source = 'compute', type_of_mesh = 'cartesian', material_source = 'hardcode',
 interpol = F, w_stride = 1, w_fault = F, use_topography = F,
 topo = 1d0, mollify_source = F
/

&block_list
 btp(1)%nqrs = 41, 21, 21, btp(1)%aqrs = -1d0, -1d0, 0d0,
 btp(1)%bqrs = 0d0, 1d0, 2d0, btp(1)%rho_s_p = 2.7d0, 3.464d0, 6d0,
 btp(1)%lqrs = 1, 1, 2, btp(1)%rqrs = 0, 1, 1,
 btp(1)%pml_lqrs = F, F, F, btp(1)%pml_rqrs = F, F, F, btp(1)%npml = 0,
 btp(2)%nqrs = 81, 21, 21, btp(2)%aqrs = 0d0, -1d0, 0d0,
 btp(2)%bqrs = 2d0, 1d0, 2d0, btp(2)%rho_s_p = 2.7d0, 3.464d0, 6d0,
 btp(2)%lqrs = 0, 1, 2, btp(2)%rqrs = 1, 1, 1,
 btp(2)%pml_lqrs = F, F, F, btp(2)%pml_rqrs = F, F, F, btp(2)%npml = 0
/

&anelastic_Q4_list
 Qs0 = 50d0, Qp0 = 50d0, fref = 1d0
/

&moment_list
 use_moment_tensor = F, order = 4
/
&mms_list
 use_mms = F
/
&output_list
 output_exact_moment = F, output_seismograms = F, output_station_info = F,
 output_fault_topo = F, output_fields_block1 = F, output_fields_block2 = F,
 stride_fields = 1
/
