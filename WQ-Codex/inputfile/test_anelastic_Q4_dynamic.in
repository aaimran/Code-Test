waveqlab3d input file: nonzero-source anelastic-Q4 dynamics regression

&problem_list
 name = 'data/test_anelastic_Q4_dynamic', problem = 'default',
 response = 'anelastic-Q4', nblocks = 1, t_final = 0.02d0, CFL = 0.25d0,
 coupling = 'locked', fd_type = 'upwind', order = 4,
 mesh_source = 'compute', type_of_mesh = 'cartesian', material_source = 'hardcode',
 interpol = F, w_stride = 1, w_fault = F, use_topography = F,
 topo = 1d0, mollify_source = F
/

&block_list
