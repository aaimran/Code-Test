 btp(1)%aqrs = -2d0, -2d0, -2d0, btp(1)%bqrs = 2d0, 2d0, 2d0,
 btp(1)%rho_s_p = 2.7d0, 3.464d0, 6d0,
 btp(1)%lqrs = 1, 1, 1, btp(1)%rqrs = 1, 1, 1,
 btp(1)%pml_lqrs = F, F, F, btp(1)%pml_rqrs = F, F, F,
 btp(1)%npml = 0
/

&anelastic_Q4_list
